{
  "ConnectionStrings": {
    "MongoDb": "mongodb://localhost:27017/hypesoft"
  },

  "Redis": {
    "Configuration": "localhost:6379",
    "InstanceName": "Hypesoft:"
  },

  "Keycloak": {
    "Authority": "http://localhost:8080/realms/hypesoft",
    "PublicAuthority": "http://localhost:8080/realms/hypesoft",
    "Audience": "hypesoft-api",
    "RequireHttpsMetadata": false
  },

  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 10
  },

  "HttpsRedirection": {
    "Enabled": false
  },

  "SecurityHeaders": {
    "ContentSecurityPolicy": "default-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';"
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/hypesoft-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithCorrelationId", "WithMachineName" ]
  },

  "AllowedHosts": "*",

  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  }
}